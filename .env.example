# KoalaTrade — Environment Variables
# Copy this file to .env and fill in your keys:  cp .env.example .env
# .env is gitignored. docker-compose reads it via:  docker compose --env-file .env ...

APP_ENV=production
APP_NAME=KoalaTrade
STARTING_CASH_CENTS=1000000
DB_PATH=/data/koalatrade.db
PORT=8080

# --- Market data ---
# NO API KEYS ARE REQUIRED. Out of the box: equities (stocks/ETFs/commodities)
# come from Yahoo Finance keyless, crypto from CoinGecko keyless. The keys below
# are optional upgrades. The poller staggers refreshes across the window below to
# stay under provider rate limits.
MARKET_DATA_CACHE_SECONDS=60
MARKET_DATA_REFRESH_WINDOW_SECONDS=900
MARKET_DATA_HTTP_TIMEOUT_SECONDS=5

# CoinGecko (crypto) — keyless works, but the public API is heavily rate-limited.
# A FREE Demo key (https://www.coingecko.com/en/api -> Demo) makes crypto polling
# and history backfill fast/reliable. Sent as x-cg-demo-api-key.
COINGECKO_BASE_URL=
COINGECKO_API_KEY=

# Yahoo Finance (equities) — keyless, no registration. Base URL override only.
YAHOO_BASE_URL=

# Finnhub (equities) — OPTIONAL premium override. If set, it serves stocks/ETFs/
# commodities instead of Yahoo. Free key: https://finnhub.io/register
FINNHUB_BASE_URL=
FINNHUB_API_KEY=

# --- eSports (LoL) prediction markets ---
# Public LoL Esports API key shipped by the lolesports.com web client.
LOLESPORTS_API_KEY=0TvQnueqKa5mxJntVWt0w4LpLfEkrV1Ta8rQBb9Z
LOLESPORTS_BASE_URL=https://esports-api.lolesports.com
POLYMARKET_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_API_KEY=
ESPORTS_CACHE_SECONDS=300

# --- Admin & auth ---
# The admin user is seeded ONCE from these values if no user exists yet.
# Leave ADMIN_PASSWORD blank to disable admin.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Secret for signing session tokens. Generate with: openssl rand -base64 32
# If blank, a random secret is generated at startup (sessions reset on restart).
AUTH_SECRET=
