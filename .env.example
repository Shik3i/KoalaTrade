# KoalaTrade — Environment Variables
# Copy this file to .env and fill in your keys

APP_ENV=production
APP_NAME=KoalaTrade
STARTING_CASH_CENTS=1000000
DB_PATH=/data/koalatrade.db
PORT=8080
MARKET_DATA_PROVIDER=mock
MARKET_DATA_CACHE_SECONDS=60
FINNHUB_API_KEY=change_this_to_your_finnhub_api_key
POLYMARKET_API_KEY=
